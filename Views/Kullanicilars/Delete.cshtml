@model RestoHub.Models.Kullanicilar

@{
    ViewBag.Title = "Delete";
}
@Styles.Render("~/Content/css")
<h3>Bu kullanıcıyı silmek istediğinizden emin misiniz?</h3>
<hr />
<div>
    <dl class="dl-horizontal">

        <dt>
            RESTORAN ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Restoranlar.RestoranAdi)
        </dd>

        <dt>
            YETKİ
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Yetkiler.YetkiAdi)
        </dd>

        <dt>
            KULLANICI ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.KullaniciAdi)
        </dd>

        <dt>
            AD SOYAD
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Ad) @Html.DisplayFor(model => model.Soyad)
        </dd>

        <dt>
            E-MAİL
        </dt>

        <dd>
            @Model.Email
        </dd>

        <dt>
            TELEFON
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Telefon)
        </dd>

        <dt>
            ŞİFRE
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Sifre)
        </dd>

        <dt>
            KULLANICI DURUMU
        </dt>

        <dd>
            @if (Model.Aktif)
            {
                <span class="badge bg-success">AKTİF</span>
            }
            else
            {
                <span class="badge bg-danger">PASİF</span>
            }
        </dd>

        <dt>BAŞLAMA TARİHİ</dt>
        <dd>@Model.BaslamaTarihi.ToShortDateString()</dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="SİL" class="btn btn-danger" /> | @Html.ActionLink("TÜM KULLANICILAR", "Index", null, new { @class = "btn btn-primary" })
        </div>
    }
</div>
