@model RestoHub.Models.Siparisler

@{
    ViewBag.Title = "Delete";
}
@Styles.Render("~/Content/css")
<h3>Bu siparişi silmek istediğinizden emin misiniz?</h3>
<hr />
<div>
    <dl class="dl-horizontal">

        <dt>
            RESTORAN ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Restoranlar.RestoranAdi)
        </dd>

        <dt>
            MASA KODU
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Masalar.MasaKodu)
        </dd>

        <dt>
            DURUM ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.SiparisDurumlari.DurumAdi)
        </dd>

        <dt>
            OLUŞTURAN ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Kullanicilar.KullaniciAdi)
        </dd>

        <dt>
            SERVİS YAPAN ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Kullanicilar1.KullaniciAdi)
        </dd>

        <dt>
            MİSAFİR ADI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.MisafirAdi)
        </dd>

        <dt>
            KİŞİ SAYISI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.KisiSayisi)
        </dd>

        <dt>
            ARA TOPLAM
        </dt>

        <dd>
            @Html.DisplayFor(model => model.AraToplam)
        </dd>

        <dt>
            İNDİRİM TUTARI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.IndirimTutari)
        </dd>

        <dt>
            KDV TUTARI
        </dt>

        <dd>
            @Html.DisplayFor(model => model.KDVTutari)
        </dd>

        <dt>
            TOPLAM TUTAR
        </dt>

        <dd>
            @Html.DisplayFor(model => model.ToplamTutar)
        </dd>

        <dt>
            ÖDEME DURUMU
        </dt>

        <dd>
            @Html.DisplayFor(model => model.OdemeDurumu)
        </dd>

        <dt>
            ÖDEME YÖNTEMİ
        </dt>

        <dd>
            @Html.DisplayFor(model => model.OdemeYontemi)
        </dd>

        <dt>
            NOTLAR
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Notlar)
        </dd>

        <dt>
            İPTAL NEDENİ
        </dt>

        <dd>
            @Html.DisplayFor(model => model.IptalNedeni)
        </dd>

        <dt>
            SİPARİŞ TARİHİ
        </dt>

        <dd>
            @Html.DisplayFor(model => model.SiparisTarihi)
        </dd>

        <dt>
            TAMAMLANMA TARİHİ
        </dt>

        <dd>
            @Html.DisplayFor(model => model.TamamlanmaTarihi)
        </dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="SİL" class="btn btn-danger" /> | @Html.ActionLink("TÜM SİPARİŞLER", "Index", null, new { @class = "btn btn-primary" })
        </div>
    }
</div>
