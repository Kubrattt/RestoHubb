@model RestoHub.Models.Siparisler
@{
    ViewBag.Title = "Masa Detay & Ödeme";
    Layout = "~/Views/Shared/_RestorantLayout.cshtml";
    var masa = ViewBag.Masa as RestoHub.Models.Masalar;
    int yetkiId = Session["YetkiId"] != null ? (int)Session["YetkiId"] : 0;

    // Yetki Grupları
    bool odemeYetkisi = new int[] { 1, 2, 3, 6 }.Contains(yetkiId);
    bool personelYetkisi = new int[] { 4, 5 }.Contains(yetkiId);
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-0 fw-bold">@masa.MasaAdi</h3>
                        <p class="mb-0 opacity-75"><i class="fas fa-map-marker-alt me-1"></i> @masa.Konum</p>
                    </div>
                    <div>
                        <a href="@Url.Action("DurumGuncelle", "Masalars")" class="btn btn-outline-light px-4">
                            <i class="fas fa-arrow-left me-1"></i> Masalara Dön
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="@(odemeYetkisi && Model != null ? "col-lg-8" : "col-12")">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-list-ul me-2"></i>Aktif Sipariş İçeriği</h5>
                </div>
                <div class="card-body">
                    @if (Model == null || !Model.SiparisDetaylari.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-receipt fa-4x text-muted opacity-25 mb-3"></i>
                            <h4 class="text-secondary fw-bold">Aktif Sipariş Bulunamadı</h4>
                            <p class="text-muted mb-4">Masa dolu ancak henüz ürün girişi yapılmamış.</p>

                            @if (odemeYetkisi || yetkiId == 4)
                            {
                                <a href="@Url.Action("Create", "Siparisler", new { masaId = masa.MasaId })" class="btn btn-primary btn-lg shadow-sm">
                                    <i class="fas fa-plus-circle me-1"></i> Yeni Sipariş / Ürün Ekle
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ürün / Notlar</th>
                                        <th class="text-center">Miktar</th>
                                        <th class="text-end">Birim Fiyat</th>
                                        <th class="text-end">İndirim</th>
                                        <th class="text-end">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var detay in Model.SiparisDetaylari)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold">@detay.Urunler.UrunAdi</div>
                                                @if (!string.IsNullOrEmpty(detay.Notlar))
                                                {
                                                    <small class="text-muted"><i class="fas fa-comment-dots me-1"></i>@detay.Notlar</small>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info text-dark rounded-pill px-3">@detay.Miktar.ToString("N2")</span>
                                            </td>
                                            <td class="text-end">@detay.BirimFiyat.ToString("N2") ₺</td>
                                            <td class="text-end text-muted small">@((detay.IndirimTutari ?? 0).ToString("N2")) ₺</td>
                                            <td class="text-end fw-bold">@detay.ToplamFiyat.ToString("N2") ₺</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 p-3 bg-light rounded border-end border-danger border-4">
                            <span class="h5 mb-0 fw-bold">Ödenecek Genel Toplam:</span>
                            <span class="h3 mb-0 fw-bold text-danger">
                                @Model.SiparisDetaylari.Sum(x => x.ToplamFiyat).ToString("N2") ₺
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (odemeYetkisi && Model != null)
        {
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm border-top border-success border-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-success"><i class="fas fa-cash-register me-2"></i>Hızlı Tahsilat</h5>
                    </div>
                    <div class="card-body">
                        @using (Html.BeginForm("OdemeYap", "Masalars", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="siparisId" value="@Model.SiparisId" />

                            <div class="mb-4">
                                <label class="form-label fw-bold small text-muted">ÖDEME YÖNTEMİ</label>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <input type="radio" class="btn-check" name="odemeYontemi" id="nakit" value="Nakit" checked>
                                        <label class="btn btn-outline-success w-100 py-3" for="nakit">
                                            <i class="fas fa-money-bill-wave d-block mb-1"></i> Nakit
                                        </label>
                                    </div>
                                    <div class="col-6">
                                        <input type="radio" class="btn-check" name="odemeYontemi" id="kart" value="Kredi Kartı">
                                        <label class="btn btn-outline-success w-100 py-3" for="kart">
                                            <i class="fas fa-credit-card d-block mb-1"></i> Kredi Kartı
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold small text-muted">TAHSİL EDİLECEK TUTAR</label>
                                <div class="input-group input-group-lg">
                                    @{
                                        var genelToplam = Model.SiparisDetaylari.Sum(x => x.ToplamFiyat);
                                        var inputToplam = genelToplam.ToString("F2").Replace(",", ".");
                                    }
                                    <input type="number" step="0.01" name="odenenTutar" class="form-control fw-bold text-danger"
                                           value="@inputToplam" required />
                                    <span class="input-group-text bg-success text-white">₺</span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-success btn-lg w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-check-circle me-1"></i> TAHSİLATI TAMAMLA
                            </button>

                            <div class="alert alert-warning mt-3 mb-0 small text-center border-0">
                                <i class="fas fa-info-circle me-1"></i> Bu işlemden sonra masa <strong>boşaltılacaktır.</strong>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>