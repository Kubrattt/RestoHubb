@model RestoHub.Models.Siparisler
@{
    ViewBag.Title = "Masa Detay & Ödeme";
    Layout = "~/Views/Shared/_RestorantLayout.cshtml";
    var masa = ViewBag.Masa as RestoHub.Models.Masalar;
    int yetkiId = Session["YetkiId"] != null ? (int)Session["YetkiId"] : 0;

    // Yetki Grupları: SüperAdmin(1), Sahip(2), Müdür(3), Kasiyer(6)
    bool odemeYetkisi = new int[] { 1, 2, 3, 6 }.Contains(yetkiId);
}

<div class="container-fluid py-4">
    @if (TempData["hata"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["hata"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-0 fw-bold">@(masa != null ? masa.MasaAdi : "Masa Bilgisi")</h3>
                        <p class="mb-0 opacity-75"><i class="fas fa-map-marker-alt me-1"></i> @(masa != null ? masa.Konum : "-")</p>
                    </div>
                    <a href="@Url.Action("DurumGuncelle", "Masalars")" class="btn btn-outline-light">
                        <i class="fas fa-arrow-left me-1"></i> Geri Dön
                    </a>
                </div>
            </div>
        </div>

        @if (Model == null)
        {
            @* MASA DOLU AMA SİPARİŞ YOKSA PATLAMAMASI İÇİN BURASI EKLENDİ *@
            <div class="col-12 text-center py-5">
                <div class="card shadow-sm border-0 p-5">
                    <i class="fas fa-receipt fa-4x text-muted mb-3"></i>
                    <h4 class="text-secondary fw-bold">Aktif Sipariş Bulunamadı</h4>
                    <p class="text-muted">Masa dolu görünüyor ancak henüz bir sipariş kaydı açılmamış.</p>
                    <div class="d-flex justify-content-center gap-2 mt-3">
                        <a href="@Url.Action("Create", "Siparislers", new { masaId = masa?.MasaId })" class="btn btn-primary px-4">
                            <i class="fas fa-plus-circle me-1"></i> Yeni Sipariş Aç
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="@(odemeYetkisi ? "col-lg-8" : "col-12")">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-list-ul me-2"></i>Sipariş Detayları</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ürün</th>
                                        <th class="text-center">Miktar</th>
                                        <th class="text-end">Toplam</th>
                                        <th class="text-center">Mutfak Durumu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.SiparisDetaylari != null && Model.SiparisDetaylari.Any())
                                    {
                                        foreach (var detay in Model.SiparisDetaylari)
                                        {
                                            <tr>
                                                <td><div class="fw-bold">@(detay.Urunler != null ? detay.Urunler.UrunAdi : "Bilinmeyen Ürün")</div></td>
                                                <td class="text-center">@detay.Miktar.ToString("N2")</td>
                                                <td class="text-end fw-bold">@detay.ToplamFiyat.ToString("N2") ₺</td>
                                                <td class="text-center">
                                                    @{
                                                        string durum = detay.SiparisDurumlari?.DurumAdi ?? "Bekliyor";
                                                        string badgeClass = durum == "Bekliyor" ? "warning text-dark" : (durum == "Hazır" ? "success" : "primary");
                                                    }
                                                    <span class="badge bg-@badgeClass">@durum</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted italic">Siparişe henüz ürün eklenmemiş.</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-info">
                                        <td colspan="2" class="text-end fw-bold">GENEL TOPLAM:</td>
                                        <td class="text-end fw-bold text-danger fs-5">
                                            @((Model.SiparisDetaylari != null ? Model.SiparisDetaylari.Sum(x => x.ToplamFiyat) : 0).ToString("N2")) ₺
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                @if (odemeYetkisi)
                {
                    <div class="card border-0 shadow-sm border-top border-success border-4">
                        <div class="card-header bg-white py-3"><h5 class="mb-0 fw-bold text-success">Tahsilat İşlemi</h5></div>
                        <div class="card-body">
                            @using (Html.BeginForm("OdemeYap", "Masalars", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="siparisId" value="@Model.SiparisId" />

                                <div class="mb-3">
                                    <label class="form-label small fw-bold">ÖDEME YÖNTEMİ</label>
                                    <select name="odemeYontemi" class="form-select">
                                        <option value="Nakit">Nakit</option>
                                        <option value="Kredi Kartı">Kredi Kartı</option>
                                        <option value="Banka Kartı">Banka Kartı</option>
                                    </select>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold">ÖDENECEK TUTAR</label>
                                    <div class="input-group">
                                        @* type="text" yaptık ve ismini odenenTutarStr olarak kesinleştirdik *@
                                        <input type="text" name="odenenTutarStr" class="form-control fw-bold fs-5 text-center text-danger"
                                               value="@Model.SiparisDetaylari.Sum(x => x.ToplamFiyat).ToString("N2")" required />
                                        <span class="input-group-text bg-light fw-bold">₺</span>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm py-3" onclick="return confirm('Tahsilatı onaylıyor musunuz? Bu işlemden sonra masa boşaltılacaktır.')">
                                    <i class="fas fa-check-circle me-2"></i> TAHSİLATI BİTİR
                                </button>
                            }
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <a href="@Url.Action("Create", "SiparisDetaylaris", new { sipId = Model.SiparisId })" class="btn btn-outline-primary fw-bold">
                            <i class="fas fa-plus me-1"></i> Ürün Ekle / Düzenle
                        </a>
                    </div>
                }
                else
                {
                    <div class="card border-0 shadow-sm bg-light text-center p-5">
                        <i class="fas fa-lock fa-4x mb-3 text-warning"></i>
                        <h5 class="fw-bold">Yetki Kısıtlı</h5>
                        <p class="text-muted mb-0">Sadece yetkili personel (Kasiyer/Yönetici) tahsilat işlemi gerçekleştirebilir.</p>
                    </div>
                }
            </div>
        }
    </div>
</div>